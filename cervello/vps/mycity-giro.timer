[Unit]
Description=MyCity AD — giro di perlustrazione automatico (il volano dell'apprendimento)

[Timer]
# RIATTIVATO (2026-07-02, richiesta Nicola: «massimo potenziale il prima possibile»).
# Giro ogni 2 ore nelle ore di veglia (06-22), al minuto :20 per non sovrapporsi
# ai timer del ritmo (06:00 / 12:00 / 18:00) e al watch-main.
# ⚠️ Consuma quota del motore AI (Cursor/Claude): se i limiti mordono, allarga a /3 o /4.
OnCalendar=*-*-* 06..22/2:20:00 Europe/Rome
Persistent=true

[Install]
WantedBy=timers.target
