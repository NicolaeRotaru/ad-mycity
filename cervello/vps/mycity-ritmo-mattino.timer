[Unit]
Description=MyCity AD — lancia il piano del mattino ogni giorno alle 06:00 (Piacenza)

[Timer]
# NOTA: "Timezone=" non è una direttiva systemd valida (il vecchio file falliva in silenzio):
# il fuso si mette DENTRO OnCalendar.
OnCalendar=*-*-* 06:00:00 Europe/Rome
Persistent=true

[Install]
WantedBy=timers.target
