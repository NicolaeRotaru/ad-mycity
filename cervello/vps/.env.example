# Segreti del VPS per il cervello MyCity. Copia in .env e compila.
# Formato KEY=valore (compatibile con systemd EnvironmentFile e con bash 'source').
# Niente virgolette, niente spazi attorno a '='. NON committare il vero .env.

# --- Memoria dell'AD (Supabase del progetto MEMORIA, NON del marketplace) --- [OBBLIGATORIO]
# Da qui worker/giro leggono la coda 'lavori', il kill-switch 'impostazioni.pausa', e salvano i briefing.
SUPABASE_URL=https://LA-MEMORIA.supabase.co
SUPABASE_SERVICE_KEY=eyJ_service_role_della_MEMORIA

# --- Dati reali del marketplace (SOLA LETTURA) --- [OPZIONALE]
MARKETPLACE_SUPABASE_URL=
MARKETPLACE_SUPABASE_KEY=

# --- Sync del vault su GitHub (il Pannello lo legge via OBSIDIAN_*) --- [CONSIGLIATO]
# GIT_BRANCH deve combaciare con OBSIDIAN_BRANCH del Pannello (cosi' vede cio' che il giro scrive).
# GIT_PUSH_TOKEN = PAT GitHub "fine-grained" con permesso Contents: Read and write sul repo ad-mycity.
GIT_REPO=NicolaeRotaru/ad-mycity
GIT_BRANCH=main
GIT_PUSH_TOKEN=github_pat_xxxxxxxx

# --- Sicurezza azioni ---
# 0 = le azioni 🔴 NON partono da sole (restano dry-run finche' non le approvi nel Pannello).
AZIONI_LIVE=0

# --- Worker --- [OPZIONALE]
# Secondi tra un controllo e l'altro della coda lavori.
WORKER_INTERVALLO=30
