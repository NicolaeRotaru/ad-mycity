# Segreti del VPS per il cervello MyCity. Copia in .env e compila.
# Formato KEY=valore (compatibile con systemd EnvironmentFile e con bash 'source').
# Niente virgolette, niente spazi attorno a '='. NON committare il vero .env.

# --- Motore AI (il "cervello" che ragiona) --- [OBBLIGATORIO sceglierne uno]
# CERVELLO_MOTORE = auto (consigliato) | claude | cursor
# auto = agent se in PATH, altrimenti claude — evita crash se cursor forzato ma agent assente
CERVELLO_MOTORE=auto
# Chiave API Cursor (per il motore 'cursor'). Creala su cursor.com/dashboard -> API Keys.
# In alternativa puoi fare il login interattivo una volta: sudo -u mycity -H agent login (allora lasciala vuota).
CURSOR_API_KEY=
# Modello opzionale (es. composer-2.5 per Cursor, claude-4.6-sonnet per Claude). Vuoto = default del motore.
CERVELLO_MODELLO=

# --- Memoria dell'AD (Supabase del progetto MEMORIA, NON del marketplace) --- [OBBLIGATORIO]
# ⚠️ NON usare clmpyfvpvfjgeviworth qui: è il DB del marketplace (ordini/negozi).
#    Le tabelle lavori/impostazioni/briefings vivono SOLO nel progetto memoria separato.
#    Copia gli stessi valori di SUPABASE_URL + SUPABASE_SERVICE_KEY dal Pannello (Vercel).
SUPABASE_URL=https://xjljcsorpbqwttrejqte.supabase.co
SUPABASE_SERVICE_KEY=eyJ_service_role_del_progetto_MEMORIA

# --- Dati reali del marketplace --- [OPZIONALE]
MARKETPLACE_SUPABASE_URL=
MARKETPLACE_SUPABASE_KEY=                 # SOLA LETTURA (anon/read): metriche e liste.
MARKETPLACE_SUPABASE_WRITE_KEY=          # SCRITTURA (service_role): usata da esegui-azione.mjs/marketplace.mjs SOLO in LIVE.

# --- Codice del marketplace (per radiografia/audit/tech) --- [CONSIGLIATO]
# Il setup.sh clona il repo del marketplace e l'AD lo legge per analizzarlo (SOLA LETTURA).
MARKETPLACE_GIT_REPO=NicolaeRotaru/mycity   # owner/repo del codice del sito (pubblico)
MARKETPLACE_BRANCH=main                      # ramo da seguire
MARKETPLACE_REPO=/opt/mycity/marketplace     # percorso della copia locale (lo usa anche cron/CI)
# MARKETPLACE_GIT_TOKEN=                      # PAT con Contents + Pull requests su mycity (push PR/merge)

# --- Sync della memoria su GitHub (il Pannello la legge via OBSIDIAN_*) --- [CONSIGLIATO]
# GIT_BRANCH = il RAMO DEDICATO dell'AD dove il giro pubblica la sua memoria (ramo dedicato, zero conflitti).  # AR-101: pubblicazione via PR/merge, niente riscrittura di storia
#   Tienilo a 'memoria-ad' (NON 'main'): su main altre sessioni toccano gli stessi file e il push fallisce.
#   Deve combaciare con OBSIDIAN_BRANCH del Pannello (Vercel), cosi' la Cabina legge cio' che il giro scrive.
# GIT_PUSH_TOKEN = PAT GitHub "fine-grained" con permessi Contents + Pull requests (Read and write)
#   su ad-mycity. Usato da git-pr.mjs / git-merge.mjs / push memoria-ad.
GIT_REPO=NicolaeRotaru/ad-mycity
GIT_BRANCH=memoria-ad
GIT_PUSH_TOKEN=github_pat_xxxxxxxx
# Email autore dei commit del giro/worker. DEVE essere collegata al tuo account GitHub,
# altrimenti Vercel rifiuta il deploy quando mergi memoria-ad in main ("No GitHub account...").
# Usa il tuo noreply GitHub (Settings -> Emails) oppure l'email principale verificata.
GIT_AUTHOR_EMAIL=98592323+NicolaeRotaru@users.noreply.github.com
# ⚠️ Virgolette obbligatorie (spazi nel valore): senza, bash → "MyCity: command not found"
GIT_AUTHOR_NAME="AD MyCity VPS"

# --- Sicurezza azioni ---
# Kill-switch invii reali (email Resend + n8n + scritture marketplace). 0/off = dry-run (default).
# 1 (o "on") = invii REALI. Accettato sia "1" sia "on" da pannello e script.
AZIONI_LIVE=0
# Autopilota dello scheduler autonomo (cervello/autopilot.mjs + publishers). 0 = non pubblica da solo.
AUTOPILOT_LIVE=0

# --- Mani secondarie (canali extra) --- [OPZIONALE]
RESEND_API_KEY=                          # email reali (Resend)
RESEND_FROM=MyCity <no-reply@mycity.example>
TELEGRAM_BOT_TOKEN=                       # notifiche Telegram (esegui-azione.mjs notifica)
TELEGRAM_CHAT_ID=
N8N_WEBHOOK_URL=                          # hub n8n (instrada WhatsApp/social/Google/...)

# --- Setup VPS (usati da cervello/vps/setup.sh) --- [per il primo deploy]
# Il clone/aggiornamento del repo: ramo del CODICE e token di lettura per il repo privato.
REPO_BRANCH=main
GIT_TOKEN=github_pat_xxxxxxxx            # può coincidere con GIT_PUSH_TOKEN

# --- Worker --- [OPZIONALE]
WORKER_INTERVALLO=5                       # secondi tra un controllo e l'altro della coda lavori
WORKER_TIMEOUT=900                        # secondi max per chat/azioni (oltre → stato "errore")
WORKER_TIMEOUT_GIRO=2700                  # 45 min per giro completo (allineato al Pannello)
