[Unit]
Description=MyCity AD — punto di mezzogiorno (ritmo, motore AI Cursor 'agent' o Claude 'claude')
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=mycity
WorkingDirectory=/opt/mycity/ad-mycity
EnvironmentFile=-/opt/mycity/ad-mycity/cervello/vps/.env
Environment=HOME=/home/mycity
Environment=PATH=/home/mycity/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
Environment=TZ=Europe/Rome
ExecStart=/usr/bin/env bash /opt/mycity/ad-mycity/cervello/ritmo.sh mezzogiorno
# AR-005: un motore AI appeso non deve tenere il .service attivo per sempre (oneshot non si sovrappone,
# quindi il timer successivo non parte e il battito muore). systemd uccide il giro dopo il timeout.
TimeoutStartSec=3600
TimeoutStopSec=120
