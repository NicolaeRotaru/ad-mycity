#!/usr/bin/env bash
# 🔒 pre-commit — due cancelli su OGNI commit (non solo nel giro):
#   1) 🩺 SINTASSI shell: nessun .sh/.bash rotto entra nella storia (worker-outage 2026-07-09).
#   2) 🔑 SEGRETI: nessun token reale entra nella storia (AR-004).
#
# Ordine voluto: la sintassi gira PER PRIMA e serve solo `bash` — così vale anche sulle macchine
# senza node, dove lo scan-segreti si limita ad avvisare. Un cancello che si spegne se manca uno
# strumento non è un cancello.
#
# Installazione: `git config core.hooksPath .githooks` (versionato, lo fa cervello/installa-hooks.sh
# e il setup del VPS). Bypass di emergenza consapevole: `git commit --no-verify` (sconsigliato).

set -u

# Radice del repo (funziona anche se il commit parte da una sottocartella).
ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
SCAN="$ROOT/cervello/scan-segreti.mjs"

# ─────────────────────────────────────────────────────────────────────────────
# 1) 🩺 GATE DI SINTASSI SHELL — la causa radice del worker-outage del 2026-07-09 fu un worker.sh con
#    un errore di sintassi (case *contenuti pro* con spazio non quotato) committato e spinto su main:
#    sul VPS bash non riusciva più a leggerlo e il worker moriva a ogni avvio. Difesa: ogni .sh/.bash
#    staged DEVE passare `bash -n` (solo sintassi, non esegue nulla) PRIMA di entrare nella storia.
if command -v bash >/dev/null 2>&1; then
  _sh_rotti=""
  while IFS= read -r f; do
    case "$f" in
      *.sh|*.bash) ;;
      *) continue ;;
    esac
    # Controlla il CONTENUTO STAGED (git show :file), cioè ciò che verrà davvero committato.
    if ! git show ":$f" 2>/dev/null | bash -n 2>/dev/null; then
      _sh_rotti="$_sh_rotti $f"
    fi
  done < <(git diff --cached --name-only --diff-filter=ACM)
  if [ -n "$_sh_rotti" ]; then
    echo "" >&2
    echo "⛔ COMMIT BLOCCATO — errore di SINTASSI shell (bash -n) in:$_sh_rotti" >&2
    for f in $_sh_rotti; do
      echo "  → $f:" >&2
      git show ":$f" 2>/dev/null | bash -n 2>&1 | head -3 | sed 's/^/     /' >&2 || true
    done
    echo "" >&2
    echo "Correggi la sintassi e ri-committa. Bypass consapevole (sconsigliato): git commit --no-verify." >&2
    exit 1
  fi
fi

# ─────────────────────────────────────────────────────────────────────────────
# 2) 🔑 GATE SEGRETI (AR-004) — nessun token reale nella storia. Senza node o senza lo scanner non
#    blocchiamo il lavoro: avvisiamo e lasciamo passare (il giro fa da seconda rete). Meglio non
#    rompere i commit su una macchina senza node.
if ! command -v node >/dev/null 2>&1; then
  echo "⚠️  pre-commit: node non trovato — scan-segreti saltato (il giro resta come seconda rete)." >&2
  exit 0
fi
if [ ! -f "$SCAN" ]; then
  echo "⚠️  pre-commit: $SCAN mancante — scan-segreti saltato." >&2
  exit 0
fi

# Scansiona SOLO i file staged (git diff --cached): veloce e mirato al commit in corso.
if ! node "$SCAN" --staged >/dev/null 2>&1; then
  echo "" >&2
  echo "⛔ COMMIT BLOCCATO — possibile SEGRETO REALE nei file staged (AR-004):" >&2
  echo "" >&2
  node "$SCAN" --staged 2>&1 | tail -12 >&2 || true
  echo "" >&2
  echo "→ Rimuovi il valore dal file (usa un *.example senza valori reali), RUOTA il segreto se era" >&2
  echo "  reale, poi ri-committa. Bypass consapevole (sconsigliato): git commit --no-verify." >&2
  exit 1
fi

exit 0
