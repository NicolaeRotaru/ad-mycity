# Fonte UNICA di verità per l'install, valida sia in CI (GitHub Actions) sia in
# build/deploy su Render. Storybook 10.x dichiara peer deps in conflitto con
# React 18 (risolto via Next 15); senza questo flag `npm ci` fallisce ERESOLVE.
# Con questo file NON serve più ripetere --legacy-peer-deps nei comandi.
legacy-peer-deps=true
