@@ -0,0 +1,36 @@
+import { describe, it, expect } from 'vitest';
+import { shippingForEuro } from '@/lib/shipping';
+import { FREE_SHIPPING_THRESHOLD, SHIPPING_PER_ORDER } from '@/lib/constants';
+
+/**
+ * Sprint 1 — carrello/checkout: stima spedizione per-negozio allineata a lib/shipping.ts
+ * (stessa fonte usata da /api/orders/cod e /api/stripe/checkout).
+ */
+describe('shippingForEuro — stima per-negozio (Sprint 1)', () => {
+  const base = {
+    storeLat: null as number | null,
+    storeLng: null as number | null,
+    deliveryLat: null as number | null,
+    deliveryLng: null as number | null,
+    pickupInStore: false,
+  };
+
+  it('soglia gratis è per subtotale del singolo negozio, non globale', () => {
+    const subA = FREE_SHIPPING_THRESHOLD - 5;
+    const subB = FREE_SHIPPING_THRESHOLD;
+    const costA = shippingForEuro({ ...base, subtotal: subA });
+    const costB = shippingForEuro({ ...base, subtotal: subB });
+    expect(costA).toBe(SHIPPING_PER_ORDER);
+    expect(costB).toBe(0);
+  });
+
+  it('multi-negozio: somma dei costi per gruppo (carrello)', () => {
+    const groups = [20, 35, 10];
+    const totalShipping = groups.reduce(
+      (sum, sub) => sum + shippingForEuro({ ...base, subtotal: sub }),
+      0,
+    );
+    // 20→4.9, 35→0, 10→4.9
+    expect(totalShipping).toBeCloseTo(SHIPPING_PER_ORDER * 2, 2);
+  });
+});
