diff --git a/migrations/107_seller_storefronts_rls.sql b/migrations/107_seller_storefronts_rls.sql
new file mode 100644
index 0000000..54d9ea7
--- /dev/null
+++ b/migrations/107_seller_storefronts_rls.sql
@@ -0,0 +1,80 @@
+-- 107 — RLS vetrina: superficie pubblica limitata (radiografia Sprint 1)
+--
+-- Problema: la policy "Anyone can view approved seller profiles" permetteva a
+-- `anon` di leggere QUALSIASI colonna sui profili seller approvati via PostgREST
+-- (inclusi stripe_account_id, IBAN, KYC, wallet). Basta cambiare la select.
+--
+-- Fix (due livelli):
+--  1. Vista `seller_storefronts` = API pubblica documentata per la vetrina.
+--  2. REVOKE SELECT su `profiles` per `anon`, poi GRANT solo colonne sicure.
+--     Gli embed `profiles!products_seller_id_fkey` restano possibili ma limitati
+--     alle colonne grantate. Il proprietario (authenticated) legge la propria riga
+--     intera via policy RLS + grant authenticated invariato.
+--
+-- Idempotente.
+
+-- ---------------------------------------------------------------------------
+-- 1) Vista vetrina pubblica (solo negozi approvati)
+-- ---------------------------------------------------------------------------
+CREATE OR REPLACE VIEW public.seller_storefronts AS
+SELECT
+  id,
+  role,
+  is_approved,
+  store_name,
+  store_lat,
+  store_lng,
+  store_phone,
+  store_address,
+  store_logo,
+  store_hours,
+  store_media,
+  store_description,
+  store_customization,
+  store_site,
+  founded_year,
+  offers_express,
+  created_at,
+  referral_code
+FROM public.profiles
+WHERE is_approved = true
+  AND store_name IS NOT NULL
+  AND role = 'seller';
+
+COMMENT ON VIEW public.seller_storefronts IS
+  'Vetrina pubblica negozio (Sprint 1 radiografia). Solo colonne sicure; niente Stripe/KYC/wallet.';
+
+GRANT SELECT ON public.seller_storefronts TO anon, authenticated;
+
+-- ---------------------------------------------------------------------------
+-- 2) Colonne `profiles` leggibili da anon (embed PostgREST + query dirette)
+-- ---------------------------------------------------------------------------
+REVOKE SELECT ON TABLE public.profiles FROM anon;
+
+GRANT SELECT (
+  id,
+  role,
+  is_approved,
+  store_name,
+  store_lat,
+  store_lng,
+  store_phone,
+  store_address,
+  store_logo,
+  store_hours,
+  store_media,
+  store_description,
+  store_customization,
+  store_site,
+  founded_year,
+  offers_express,
+  created_at,
+  referral_code,
+  full_name,
+  public_profile_enabled,
+  public_handle,
+  public_bio,
+  public_avatar_url
+) ON TABLE public.profiles TO anon;
+
+NOTIFY pgrst, 'reload schema';
diff --git a/tests/integration/security/seller-storefronts-rls.test.ts b/tests/integration/security/seller-storefronts-rls.test.ts
new file mode 100644
index 0000000..57b3b43
--- /dev/null
+++ b/tests/integration/security/seller-storefronts-rls.test.ts
@@ -0,0 +1,55 @@
+import { describe, it, expect, beforeAll } from 'vitest';
+import { createClient, type SupabaseClient } from '@supabase/supabase-js';
+
+/**
+ * Migration 107 — RLS vetrina: `seller_storefronts` + colonne `profiles` limitate per anon.
+ *
+ * Verifica che un client anonimo:
+ *  - legga la vista pubblica `seller_storefronts`;
+ *  - NON legga colonne sensibili (es. stripe_account_id) su `profiles` altrui.
+ *
+ * Si salta senza env Supabase reali. Solo SELECT, nessuna mutazione.
+ */
+const URL = process.env.NEXT_PUBLIC_SUPABASE_URL;
+const ANON = process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY;
+const hasEnv = !!(URL && ANON) && !URL.includes('placeholder') && !ANON.includes('placeholder');
+
+describe.skipIf(!hasEnv)('RLS vetrina — seller_storefronts (migration 107)', () => {
+  let anon: SupabaseClient;
+
+  beforeAll(() => {
+    anon = createClient(URL!, ANON!, { auth: { persistSession: false } });
+  });
+
+  it('anon legge almeno una riga da seller_storefronts (solo colonne sicure)', async () => {
+    const { data, error } = await anon
+      .from('seller_storefronts')
+      .select('id, store_name, is_approved')
+      .limit(1);
+    expect(error, error?.message).toBeNull();
+    // Può essere 0 righe su DB vuoto; in quel caso il test non è informativo ma non fallisce.
+    if ((data ?? []).length > 0) {
+      expect(data![0]).toHaveProperty('store_name');
+      expect(data![0]).not.toHaveProperty('stripe_account_id');
+    }
+  });
+
+  it('anon NON può leggere stripe_account_id da profiles di un seller approvato', async () => {
+    const { data: storefronts } = await anon.from('seller_storefronts').select('id').limit(1);
+    const sellerId = storefronts?.[0]?.id;
+    if (!sellerId) return; // DB senza negozi: skip implicito
+
+    const { data, error } = await anon
+      .from('profiles')
+      .select('id, stripe_account_id')
+      .eq('id', sellerId)
+      .maybeSingle();
+
+    // PostgREST nega la colonna non grantata (42501) oppure non restituisce il campo.
+    const leaked = data?.stripe_account_id != null && data.stripe_account_id !== '';
+    expect(leaked, 'stripe_account_id non deve essere leggibile da anon').toBe(false);
+    if (error) {
+      expect(error.message.toLowerCase()).toMatch(/permission|column|42501|denied/);
+    }
+  });
+});
