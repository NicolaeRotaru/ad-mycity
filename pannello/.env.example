# ===========================================
#  CHIAVE SEGRETA — riempi e rinomina in .env.local
#  Questo file resta SOLO sul tuo PC. Mai online.
# ===========================================

# --- (NIENTE CHIAVE ANTHROPIC) ---
# Il Pannello NON usa le API di Claude a pagamento. Il "cervello" gira su
# Claude Code (il tuo piano Max, a quota fissa) tramite gli script in cervello/.
# Il Pannello si limita a LEGGERE e MOSTRARE cio' che il cervello-Max salva in memoria.

# --- GITHUB (per ANALIZZARE il marketplace mycity) ---  [OPZIONALE]
# Serve per far LEGGERE al Pannello il codice del sito (SOLA LETTURA) via GitHub API.
# Endpoint: GET /api/marketplace/codice · /api/marketplace/codice?azione=lista · ?path=src/...
# Senza queste variabili i DATI (ordini/clienti) funzionano lo stesso via MARKETPLACE_SUPABASE_*.
# Token "fine-grained" con permesso di sola lettura su "Contents" del repo mycity.
GITHUB_TOKEN=github_pat_xxxxxxxx
GITHUB_OWNER=NicolaeRotaru
GITHUB_REPO=mycity
GITHUB_DEFAULT_BRANCH=main

# ===========================================
#  DUE DATABASE SEPARATI (non confonderli!)
# ===========================================

# --- 1) DATABASE DEL MARKETPLACE (mycity) ---  [per i DATI REALI]
# Da QUI l'assistente LEGGE ordini, clienti, incassi (il codice fa SOLO GET).
# Le tabelle hanno la sicurezza RLS attiva: serve la chiave "service_role"
# (Supabase -> Settings -> API -> service_role). Resta SOLO sul server (Vercel),
# non finisce mai nel browser.
MARKETPLACE_SUPABASE_URL=https://clmpyfvpvfjgeviworth.supabase.co
MARKETPLACE_SUPABASE_KEY=eyJ...service_role...

# --- 2) DATABASE MEMORIA dell'assistente ---  [per restare "vivo"]
# QUI l'assistente SCRIVE i suoi giri/briefing. E' un progetto Supabase DIVERSO,
# dedicato all'assistente (tabella "briefings", vedi LEGGIMI.md).
# Senza, gira lo stesso ma non ricorda i giri.
SUPABASE_URL=https://LA-MEMORIA.supabase.co
SUPABASE_SERVICE_KEY=eyJxxxxxxxx

# --- BATTITO AUTONOMO (il cron che rilegge l'ultimo giro) ---  [CONSIGLIATO online]
# Una parola segreta a tua scelta: protegge l'endpoint del battito.
# NB: il battito NON genera nulla via API: accoda un "giro" al cervello-Max e
# rilegge l'ultimo briefing dalla memoria. In test puoi lasciarla vuota.
CRON_SECRET=

# --- OBSIDIAN / VAULT (la memoria del business) ---  [per la "memoria viva" nel Pannello]
# Da qui il Pannello LEGGE il vault (cartella MyCity-Vault/) via GitHub API.
# OBSIDIAN_REPO = il repo che CONTIENE la cartella MyCity-Vault/ -> e' "ad-mycity" (NON un repo a parte).
# OBSIDIAN_TOKEN = un PAT con almeno Contents: Read su quel repo (per scrivere serve Read and write).
# OBSIDIAN_BRANCH = il ramo da leggere: DEVE combaciare col GIT_BRANCH del cervello (VPS).
#   Usa 'memoria-ad' (il ramo dedicato dove il giro pubblica la memoria), NON 'main'.
OBSIDIAN_REPO_OWNER=NicolaeRotaru
OBSIDIAN_REPO=ad-mycity
OBSIDIAN_TOKEN=github_pat_xxxxxxxx
OBSIDIAN_BRANCH=memoria-ad
# OBSIDIAN_BRANCH_FALLBACK = ramo di RIPIEGO in sola lettura (default 'main'). Se un file NON
#   esiste su OBSIDIAN_BRANCH (branch assente, giro pubblicato su main per sbaglio, propagazione
#   in corso) il Pannello lo rilegge da qui invece di mostrare schermo vuoto. Il ramo che ha
#   servito i dati è visibile in /api/stato (campi vaultRamoServito / vaultRipiego). Lascialo
#   vuoto/uguale a OBSIDIAN_BRANCH per disattivare il ripiego. Le SCRITTURE restano su OBSIDIAN_BRANCH.
OBSIDIAN_BRANCH_FALLBACK=main

# --- POSTHOG (Visite sito + Conversione) ---  [OPZIONALE]
# Statistiche di traffico del sito. Personal API key (sola lettura).
# Host: https://eu.posthog.com oppure https://us.posthog.com
POSTHOG_HOST=https://eu.posthog.com
POSTHOG_PROJECT_ID=12345
POSTHOG_API_KEY=phx_xxxxxxxx

# --- n8n (le "MANI": esegue le azioni approvate) ---  [OPZIONALE]
# URL di un webhook n8n: quando approvi un'azione, l'assistente la invia qui e
# n8n fa il lavoro reale (post social, WhatsApp, email...). Senza, l'assistente
# spiega solo i passi da fare a mano.
N8N_WEBHOOK_URL=https://il-tuo-n8n/webhook/xxxx

# --- KILL-SWITCH invii reali ---  [SICUREZZA]
# Interruttore unico per email (Resend) e webhook n8n. OFF di default: le azioni si
# SIMULANO (niente invii). Per inviare DAVVERO imposta AZIONI_LIVE=1 (accetta anche "on").
# Tienilo spento finché l'accesso al pannello non è protetto (Vercel Deployment Protection).
AZIONI_LIVE=0
